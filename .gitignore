# Dependencies
node_modules/

# Build output
dist/
src-tauri/target/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Environment
.env
.env.local
.env.*.local

# Tauri
src-tauri/gen/

# Logs
*.log
npm-debug.log*

# Secrets
*.pem
*.p12
*.key

# ATL
.atl/

# Local scratch
tmp/

# Build installers / distributable binaries
# These are regenerated by `pnpm tauri build`; never commit them.
# (src-tauri/icons/*.ico + *.icns stay tracked — they are source assets,
#  not build output, and .gitignore is evaluated per-path.)
dist-binaries/
*.msi
*.dmg
*.AppImage
*.deb
*.app.zip
# NSIS/setup installers live under src-tauri/target/ which is already ignored,
# but cover the case of a stray copy at the repo root too.
/*-setup.exe
/dist-binaries/*.exe
